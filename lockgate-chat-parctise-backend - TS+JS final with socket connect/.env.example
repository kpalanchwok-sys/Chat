# ─── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── MongoDB ───────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/lockgate_chat

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── File Uploads ──────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
